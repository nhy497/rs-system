# NPM 配置文件
# 設置 registry 和其他配置

# 使用官方 registry
registry=https://registry.npmjs.org/

# 設置認證相關
//registry.npmjs.org/:_authToken=${NPM_TOKEN}

# 設置緩存目錄
cache=${HOME}/.npm-cache

# 設置全局安裝目錄
prefix=${HOME}/.npm-global

# 設置嚴格 SSL
strict-ssl=true

# 設置超時時間
timeout=60000

# 設置最大重試次數
retry-timeout=10000

# 設置代理（如果需要）
# proxy=http://proxy.company.com:8080
# https-proxy=http://proxy.company.com:8080
