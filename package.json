{
  "name": "rs-system",
  "version": "3.1.0",
  "description": "跳繩課堂記錄系統 - HKJRA 教練記錄系統",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test && npm run test:e2e",
    "lint": "eslint . --ext .js,.html",
    "lint:fix": "eslint . --ext .js,.html --fix",
    "format": "prettier --write \"**/*.{js,html,css,json,md}\"",
    "type-check": "tsc --noEmit",
    "test:ci": "vitest run --coverage --reporter=verbose",
    "test:e2e:ci": "playwright test --reporter=json --reporter=junit"
  },
  "keywords": [
    "rope-skipping",
    "sports",
    "coaching",
    "checkpoint",
    "training-log"
  ],
  "author": "HKJRA",
  "license": "MIT",
  "devDependencies": {
    "vite": "^5.4.10",
    "vitest": "^2.1.4",
    "@vitest/ui": "^2.1.4",
    "eslint": "^9.14.0",
    "@eslint/js": "^9.14.0",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "eslint-plugin-playwright": "^1.8.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "rollup-plugin-visualizer": "^5.12.0",
    "@playwright/test": "^1.48.2",
    "jsdom": "^25.0.1",
    "@vitest/coverage-v8": "^2.1.4"
  },
  "dependencies": {
    "pouchdb": "^8.0.1",
    "pouchdb-find": "^8.0.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
